CONFIG_PROJECT_VERSION="1.0.9"
CONFIG_BUTTON_NAME="ai_chat_button"
CONFIG_BOARD_CHOICE_T5AI=y
CONFIG_BOARD_CHOICE_TUYA_T5AI_CORE=y
CONFIG_ENABLE_LIBU8G2=y
CONFIG_ENABLE_DISPLAY=y
CONFIG_DISPLAY_NAME="signal_oled"
CONFIG_ENABLE_BLUETOOTH=y
CONFIG_ENABLE_I2C=y
CONFIG_ENABLE_UART=y
CONFIG_ENABLE_MBEDTLS_SSL_MAX_CONTENT_LEN=4096
# CONFIG_ENABLE_LIBLVGL is not set
# CONFIG_ENABLE_COMP_AI_DISPLAY is not set
CONFIG_APP_NEED_AI_COMPONENTS=y
CONFIG_ENABLE_AI_COMPONENTS=y
CONFIG_ENABLE_COMP_AI_PRESENT_MODE=y
CONFIG_ENABLE_COMP_AI_MODE_HOLD=y
CONFIG_ENABLE_COMP_AI_MODE_ONESHOT=y
CONFIG_ENABLE_COMP_AI_MODE_WAKEUP=y
CONFIG_ENABLE_COMP_AI_MODE_FREE=y
CONFIG_ENABLE_COMP_AI_AUDIO=y
CONFIG_ENABLE_COMP_AI_AUDIO_CODEC_PCM=y
CONFIG_ENABLE_COMP_AI_MCP=y
